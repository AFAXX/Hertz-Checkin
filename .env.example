# ============================================================
# Hertz Malta Check-in — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.

# ---- DATABASE (Required) ----
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# ---- NEXTAUTH (Required for Microsoft 365 Login) ----
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=https://your-app.vercel.app

# ---- AZURE AD / MICROSOFT 365 LOGIN (Required for Admin Access) ----
AZURE_AD_CLIENT_ID=your-azure-ad-client-id
AZURE_AD_CLIENT_SECRET=your-azure-ad-client-secret
AZURE_AD_TENANT_ID=your-azure-ad-tenant-id

# ---- MICROSOFT GRAPH API / SHAREPOINT (Optional) ----
GRAPH_TENANT_ID=your-graph-tenant-id
GRAPH_CLIENT_ID=your-graph-client-id
GRAPH_CLIENT_SECRET=your-graph-client-secret
GRAPH_SITE_ID=your-sharepoint-site-id
GRAPH_DRIVE_ID=your-sharepoint-drive-id

# ---- MISC (Optional) ----
TOKEN_EXPIRATION_HOURS=6
NOTIFICATION_EMAIL=
