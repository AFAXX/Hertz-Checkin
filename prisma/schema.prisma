generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model RentalContract {
  id            String     @id @default(cuid())
  contractNumber String    @unique
  customerName  String
  customerEmail String?
  customerPhone String?
  vehiclePlate  String
  vehicleModel  String
  vehicleColor  String?
  status        String     @default("pending") // pending | in_progress | completed | archived
  archivedAt    DateTime?  // Set when contract moves to archive (after 04:00 AM next day)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  tokens        AccessToken[]
  photos        PhotoSubmission[]
}

model AccessToken {
  id            String   @id @default(cuid())
  token         String   @unique
  contractId    String
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime @default(now())

  contract      RentalContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
}

model PhotoRequirement {
  id          String   @id @default(cuid())
  key         String   @unique  // e.g. "front", "rear", "left_side"
  label       String            // e.g. "Vista anteriore"
  labelEn     String?           // English label
  description String?           // Brief instructions
  orderIndex  Int     @default(0)
  required    Boolean @default(true)
  icon        String?           // Lucide icon name

  submissions PhotoSubmission[]
}

model PhotoSubmission {
  id            String   @id @default(cuid())
  contractId    String
  requirementId String
  fileName      String
  fileSize      Int
  mimeType      String
  // Local storage path (during development / fallback)
  localPath     String?
  // Microsoft Graph API upload URL / item ID
  graphItemId   String?
  graphDriveId  String?
  // Timestamp & Geolocation
  capturedAt    DateTime @default(now())  // ISO 8601 timestamp generated server-side on upload
  latitude      Float?                     // GPS latitude from browser geolocation
  longitude     Float?                     // GPS longitude from browser geolocation
  uploadedAt    DateTime @default(now())

  contract      RentalContract     @relation(fields: [contractId], references: [id], onDelete: Cascade)
  requirement   PhotoRequirement   @relation(fields: [requirementId], references: [id], onDelete: Cascade)
}

// NextAuth.js models for Microsoft 365 login
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
